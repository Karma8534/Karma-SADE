# ============================================================
# KARMA HARNESS — Environment Variables
# Copy this to .env and fill in your real keys
# NEVER commit .env to git
# ============================================================

# --- Infrastructure ---
POSTGRES_PASSWORD=change_me_strong_password
REDIS_PASSWORD=change_me_redis_password
SANDBOX_TOKEN=change_me_sandbox_token

# --- Karma Identity ---
KARMA_VERSION=1.0.0
KARMA_ENV=development

# --- Anthropic ---
ANTHROPIC_API_KEY=sk-ant-...

# --- Google Gemini ---
GOOGLE_API_KEY=AIza...

# --- OpenAI ---
OPENAI_API_KEY=sk-...

# --- z.ai (GLM/ZhipuAI) ---
ZAI_API_KEY=...
ZAI_BASE_URL=https://open.bigmodel.cn/api/paas/v4

# --- Perplexity ---
PERPLEXITY_API_KEY=pplx-...

# --- MiniMax ---
MINIMAX_API_KEY=...
MINIMAX_GROUP_ID=...

# --- Groq ---
GROQ_API_KEY=gsk_...

# --- OpenRouter (universal fallback) ---
OPENROUTER_API_KEY=sk-or-...
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1

# --- Local Ollama (K2) ---
# Set to your K2 local IP or Tailscale address
OLLAMA_BASE_URL=http://host.docker.internal:11434
OLLAMA_MODELS=qwen2.5:7b,qwen2.5-coder:7b,gemma3:4b

# --- JWT Auth ---
JWT_SECRET=change_me_jwt_secret_min_32_chars
JWT_EXPIRE_MINUTES=10080

# --- Self-Edit Engine ---
# Minutes before Karma auto-approves a self-edit if not manually actioned
SELF_EDIT_APPROVAL_WINDOW_MINUTES=15
SELF_EDIT_AUTO_APPROVE=true
