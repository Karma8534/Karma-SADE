{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "jprop6 continuity envelope",
  "type": "object",
  "required": ["schema_version", "written_at", "session"],
  "properties": {
    "schema_version": {
      "type": "string",
      "const": "jprop6.v1"
    },
    "written_at": {
      "type": "string",
      "format": "date-time"
    },
    "session": {
      "type": "object",
      "required": ["session_id", "workspace_id", "source"],
      "properties": {
        "session_id": { "type": "string", "minLength": 1 },
        "workspace_id": { "type": "string", "minLength": 1 },
        "thread_id": { "type": "string" },
        "source": { "type": "string", "enum": ["browser", "electron", "system"] },
        "last_surface_snapshot_at": { "type": "string" },
        "notes": { "type": "string" }
      },
      "additionalProperties": true
    }
  },
  "additionalProperties": false
}
