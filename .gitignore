# Python bytecode
__pycache__/
*.pyc
*.pyo

# Logs (rotated, runtime — not source)
Logs/*.log
Logs/*.json
Logs/screenshots/

# Temp debug/test scripts (prefixed with underscore)
Scripts/_test_*.py
Scripts/_debug_*.py
Scripts/_fix_*.py
Scripts/_check_*.py
Scripts/_db_*.py

# OS junk
Thumbs.db
desktop.ini
.DS_Store

# Editor artifacts
*.swp
*.swo
*~
.vscode/

# Secrets (DPAPI-encrypted, but still shouldn't be in repo)
# Actual file lives at ~/karma/secrets.json, outside repo tree.
secrets.json

# Vault token file (local-only)
.vault_token
.vault-token
.hub-chat-token

# Local-only worktree and test artifacts
.worktrees/
.claude/worktrees/elegant-solomon/
chrome-extension/test-extension.js

# Karma context snapshot (generated at CC session start, machine-local)
karma-context.md
karma-context.md.tmp
cc-session-brief.md
