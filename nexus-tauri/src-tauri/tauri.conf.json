{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "ArknexusV6",
  "version": "0.1.0",
  "identifier": "net.arknexus.v6",
  "build": {
    "frontendDist": "../../frontend/out"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "ArknexusV6",
        "width": 1366,
        "height": 900,
        "minWidth": 1024,
        "minHeight": 700,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
